# ── Konosuba Bot Platform — Environment Variables ──────────────────────────────
#
# Copy this file to .env and fill in your values.
# On Render: set these in the Environment Variables section of your service.
#
# IMPORTANT: Never commit .env to git.

# MongoDB connection string (required)
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/?appName=your-app

# JWT secret — use a long random string (required)
JWT_SECRET=replace-with-very-long-random-secret-at-least-64-chars

# Admin dashboard password (required for /admin route)
ADMIN_PASSWORD=replace-with-strong-admin-password

# Bot webhook secret — shared between bot and server (required)
BOT_WEBHOOK_SECRET=replace-with-random-webhook-secret

# Your Render deployment URL (used by the bot to locate the server)
WEBSITE_URL=https://your-app.onrender.com

# WhatsApp owner phone number (with country code, no +)
OWNER_NUMBERS=1234567890

# Server port (automatically set by Render — do NOT set this manually)
# PORT=10000
