# MongoDB
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/konosuba

# Auth
JWT_SECRET=your_very_long_random_secret_here

# Admin
ADMIN_PASSWORD=your_admin_password_here

# Bot webhook security (shared secret between bot and server)
BOT_WEBHOOK_SECRET=your_webhook_secret_here

# Bot owner WhatsApp numbers (comma-separated, with country code, no spaces or +)
OWNER_NUMBERS=2347061426124

# Website URL (your Render service URL)
WEBSITE_URL=https://your-app.onrender.com

# Bot command prefix
PREFIX=.

# Node environment
NODE_ENV=production

# Port (Render sets this automatically — do not override on Render)
# PORT=5000
