# API base URL — set this to your Render API service URL
# The website uses relative /api paths which work when both are same domain.
# If deploying to a different domain, set this:
# VITE_API_BASE=https://your-api.onrender.com

# For Render static site:
# Build command: npm install && npm run build
# Publish directory: dist
# BASE_PATH=/   (if serving at root)
