# ─────────────────────────────────────────────────
#  Konosuba Bot — Environment Variables
#  Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────

# MongoDB connection string (from MongoDB Atlas)
MONGO_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/konosuba?retryWrites=true&w=majority

# Secret used to sign JWT tokens (make this long and random)
JWT_SECRET=replace_with_a_long_random_string_at_least_32_chars

# Shared secret between bot and website API (must match on both sides)
BOT_WEBHOOK_SECRET=replace_with_another_long_random_string

# Your Vercel website URL (used for CORS — no trailing slash)
# Example: https://konosuba-website.vercel.app
WEBSITE_URL=https://your-vercel-site.vercel.app

# Port (Render sets this automatically — do not change)
# PORT=3000
