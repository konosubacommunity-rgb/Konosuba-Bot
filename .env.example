# MongoDB Connection String
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/?appName=YourApp

# Bot Configuration
BOT_NUMBER=your_whatsapp_number_here
PORT=3000

# JWT Secrets (generate random strings)
JWT_SECRET=generate_a_random_string_here_at_least_32_chars_long
BOT_WEBHOOK_SECRET=another_random_string_for_webhook_security

# Website API (for syncing user data)
WEBSITE_API_URL=https://your-website.com/api

# Optional: Additional settings
NODE_ENV=production
